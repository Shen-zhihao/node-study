# 复制此文件为 .env 并按需修改：cp .env.example .env
# .env 含真实配置(可能有密钥)，已被 .gitignore 忽略，切勿提交。

# 运行环境：development | production | test
NODE_ENV=development

# 服务监听端口
PORT=3000

# 日志级别：trace | debug | info | warn | error | fatal | silent（默认 info）
# 想看更详细的调试日志时设为 debug
LOG_LEVEL=info

# ── JWT 鉴权（Step 9）──
# 签名密钥：至少 16 位，生产环境务必换成足够随机的长字符串（泄露 = 任何人可伪造登录）
JWT_SECRET=dev_only_change_me_to_a_long_random_secret
# token 有效期：支持 15m / 24h / 7d 等格式
JWT_EXPIRES_IN=7d

# ── PostgreSQL（供 docker-compose 初始化数据库使用）──
POSTGRES_USER=node_study
POSTGRES_PASSWORD=change_me
POSTGRES_DB=node_study
POSTGRES_PORT=5432

# ── 数据库连接串（供应用/Prisma 使用）──
# 格式：postgresql://用户:密码@主机:端口/库名?参数
DATABASE_URL=postgresql://node_study:change_me@localhost:5432/node_study?schema=public
